{
  "adapter": {
    "type": "mock",
    "battery": 85.0,
    "position": {"x": 1.0, "y": 2.0},
    "nav_delay": 2.0
  },
  "llm": {
    "provider": "zhipu",
    "base_url": "",
    "api_url": "",
    "model": "glm-5",
    "api_key": "replace-with-your-api-key",
    "timeout_sec": 90,
    "max_tokens": 1024,
    "retry_count": 1,
    "prompt_mode": "full"
  },
  "nav": {
    "scheme": "http",
    "host": "127.0.0.1",
    "port": 9002,
    "base_url": "",
    "timeout_sec": 15,
    "auth_token": "",
    "username": "",
    "password": ""
  },
  "rosbridge": {
    "ws_url": "",
    "scheme": "ws",
    "host": "127.0.0.1",
    "port": 8888,
    "path": "/api/rt",
    "timeout_sec": 5,
    "motion_presets": {
      "stand": {
        "linear_z": 1.0
      },
      "lie_down": {
        "linear_z": -1.0
      }
    }
  },
  "planner": {
    "motion_aliases": {
      "站立": "stand",
      "起立": "stand",
      "站起来": "stand",
      "趴下": "lie_down",
      "卧倒": "lie_down"
    }
  },
  "task_chains": {
    "storage_file": "task_chains.json"
  },
  "world_model": {
    "default_map_name": "26层"
  },
  "callback": {
    "enabled": false,
    "host": "0.0.0.0",
    "port": 8081,
    "path": "/callback/nav_event",
    "url": null,
    "max_events": 100
  },
  "world": {
    "enabled": true,
    "path": "fishmindos/world/semantic_map.json",
    "auto_switch_map": true,
    "prefer_current_map": true,
    "adapter_fallback": false
  },
  "soul": {
    "enabled": true,
    "path": "fishmindos/soul/soul.json",
    "max_memories": 200
  },
  "mission": {
    "wait_confirm_reminder_enabled": true,
    "wait_confirm_reminder_interval_sec": 20,
    "wait_confirm_reminder_text": "请确认后我再继续执行。"
  },
  "app": {
    "debug": false,
    "log_level": "INFO",
    "identity": "机器人助手",
    "prompt_profile": null,
    "language": "zh"
  }
}
